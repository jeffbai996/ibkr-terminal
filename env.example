# ibkr_mcp environment configuration
# Copy to .env and fill in your values

# IB Gateway connection
IB_HOST=127.0.0.1
IB_PORT=4001              # 4001 = IB Gateway, 7497 = TWS
IB_CLIENT_ID=10           # Must be unique per connection. Don't use 0.
IB_TIMEOUT=10             # Connection timeout in seconds
IB_READONLY=false         # Set true to disable order tools entirely

# Account settings
PRIMARY_ACCOUNT=          # Your main account ID (leave blank to auto-detect)

# Secondary gateway — dual-account mode (optional)
# Set IB_PORT_2 to a second Gateway's port to enable. Leave 0 to disable.
IB_PORT_2=0               # e.g. 4002 for a second Gateway instance
IB_CLIENT_ID_2=20         # Must be unique, different from IB_CLIENT_ID
SECONDARY_ACCOUNT=        # Secondary account ID (leave blank to auto-detect)

# HTTP server (server_http.py only)
MCP_HTTP_PORT=8000        # Port to listen on — must match Tailscale Funnel target
MCP_HTTP_HOST=0.0.0.0     # Bind address: 0.0.0.0 required for Tailscale Funnel

# Dashboard (dashboard.py) — optional, only needed for web frontend
ANTHROPIC_API_KEY=        # Claude API key for /api/query passthrough
MCP_URL=                  # MCP server URL for Claude to connect back to (e.g. http://localhost:8000/mcp)
DASHBOARD_DIST=           # Path to Vite frontend build output (default: ../ibkr-dashboard/frontend/dist)
YAHOO_CACHE_TTL=30        # Seconds to cache Yahoo Finance prices

# Persistence — NLV history database
IBKR_DB_PATH=             # SQLite file path. Default: ~/.ibkr-terminal/history.db
